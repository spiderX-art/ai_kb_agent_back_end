# 应用基础信息
APP_NAME="AI KB Agent API"
APP_VERSION="0.1.0"
DEBUG=true

# API 版本前缀，后续所有 v1 接口都会挂在这个路径下
API_V1_PREFIX="/api/v1"

# 前端本地开发地址。pydantic-settings 会按 JSON 数组解析这个值
CORS_ORIGINS='["http://localhost:5173", "http://127.0.0.1:5173"]'

# 本地先用 SQLite 文件数据库，不需要额外安装数据库服务
DATABASE_URL="sqlite:///./app.db"

# OpenAI Key 只允许放在后端环境变量里，不能写进前端代码
OPENAI_API_KEY=""
